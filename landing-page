<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Viva Experiências — Voucher Corporativo e Campanhas de Incentivo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --orange: #E8440A;
      --orange-dark: #C73A08;
      --orange-light: #FFF0EB;
      --green: #5C9E1A;
      --green-dark: #4A8015;
      --dark: #111827;
      --gray: #6B7280;
      --light: #F9FAFB;
      --white: #FFFFFF;
      --border: #E5E7EB;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      color: var(--dark);
      background: var(--white);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ── UTILITIES ── */
    .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }
    .tag {
      display: inline-block;
      background: var(--orange-light);
      color: var(--orange);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: .06em;
      text-transform: uppercase;
      padding: 6px 14px;
      border-radius: 100px;
      margin-bottom: 16px;
    }

    /* ── BUTTONS ── */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--green);
      color: #fff;
      font-size: 17px;
      font-weight: 700;
      padding: 16px 32px;
      border-radius: 8px;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: background .18s, transform .14s, box-shadow .18s;
      box-shadow: 0 4px 14px rgba(92,158,26,.35);
    }
    .btn-primary:hover {
      background: var(--green-dark);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(92,158,26,.4);
    }
    .btn-primary svg { flex-shrink: 0; }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 2px solid rgba(255,255,255,.6);
      color: #fff;
      font-size: 16px;
      font-weight: 600;
      padding: 14px 28px;
      border-radius: 8px;
      text-decoration: none;
      cursor: pointer;
      background: transparent;
      transition: border-color .18s, background .18s;
    }
    .btn-ghost:hover { border-color: #fff; background: rgba(255,255,255,.1); }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255,255,255,.97);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
    }
    .nav-inner {
      max-width: 1120px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 68px;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }
    .logo-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: var(--orange);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .logo-text { font-size: 20px; font-weight: 800; color: var(--dark); }
    .logo-text span { color: var(--orange); }
    .nav-cta {
      background: var(--orange);
      color: #fff;
      font-size: 14px;
      font-weight: 700;
      padding: 10px 22px;
      border-radius: 6px;
      text-decoration: none;
      transition: background .18s;
    }
    .nav-cta:hover { background: var(--orange-dark); }

    /* ══════════════════════════════════
       SEÇÃO 1 — HERO
    ══════════════════════════════════ */
    #hero {
      background: var(--orange);
      padding: 80px 24px 0;
      overflow: hidden;
      position: relative;
    }
    #hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 70% 50%, rgba(255,255,255,.07) 0%, transparent 65%);
    }
    .hero-inner {
      max-width: 1120px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 420px;
      gap: 48px;
      align-items: flex-end;
      position: relative;
    }
    .hero-content { padding-bottom: 72px; }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,.15);
      color: rgba(255,255,255,.9);
      font-size: 13px;
      font-weight: 600;
      padding: 6px 14px;
      border-radius: 100px;
      margin-bottom: 24px;
      letter-spacing: .04em;
    }
    .hero-eyebrow::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #fff;
      display: inline-block;
    }
    .hero-h1 {
      font-size: clamp(32px, 4.5vw, 52px);
      font-weight: 900;
      color: #fff;
      line-height: 1.1;
      letter-spacing: -.02em;
      margin-bottom: 20px;
    }
    .hero-h1 em {
      font-style: normal;
      text-decoration: underline;
      text-decoration-color: rgba(255,255,255,.5);
      text-underline-offset: 5px;
    }
    .hero-sub {
      font-size: 18px;
      color: rgba(255,255,255,.85);
      line-height: 1.6;
      max-width: 540px;
      margin-bottom: 16px;
    }
    .hero-body {
      font-size: 15px;
      color: rgba(255,255,255,.72);
      line-height: 1.7;
      max-width: 500px;
      margin-bottom: 36px;
    }
    .hero-cta-group { display: flex; flex-direction: column; gap: 12px; align-items: flex-start; }
    .hero-microcopy {
      font-size: 13px;
      color: rgba(255,255,255,.65);
    }
    .hero-microcopy strong { color: rgba(255,255,255,.85); }

    /* Hero images */
    .hero-images {
      display: flex;
      gap: 12px;
      align-items: flex-end;
      padding-bottom: 0;
    }
    .hero-img-card {
      border-radius: 16px 16px 0 0;
      overflow: hidden;
      flex: 1;
      background: rgba(255,255,255,.15);
    }
    .hero-img-card:nth-child(1) { height: 280px; }
    .hero-img-card:nth-child(2) { height: 340px; }
    .hero-img-card:nth-child(3) { height: 240px; }
    .hero-img-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .img-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 8px;
      color: rgba(255,255,255,.6);
      font-size: 28px;
      background: rgba(255,255,255,.08);
    }
    .img-placeholder span { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; }

    /* wave bottom */
    .hero-wave {
      display: block;
      width: 100%;
      margin-top: 0;
    }

    /* ══════════════════════════════════
       SEÇÃO 2 — LOGOS
    ══════════════════════════════════ */
    #logos {
      background: #fff;
      padding: 40px 24px;
      border-bottom: 1px solid var(--border);
    }
    .logos-inner {
      max-width: 1120px;
      margin: 0 auto;
    }
    .logos-label {
      text-align: center;
      font-size: 12px;
      font-weight: 600;
      color: #9CA3AF;
      letter-spacing: .1em;
      text-transform: uppercase;
      margin-bottom: 24px;
    }
    .logos-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 48px;
      flex-wrap: wrap;
    }
    .logo-pill {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 40px;
      padding: 0 20px;
      border-radius: 8px;
      border: 1.5px solid var(--border);
      font-size: 14px;
      font-weight: 700;
      color: #6B7280;
      letter-spacing: .04em;
      background: #fff;
      min-width: 120px;
    }

    /* ══════════════════════════════════
       SEÇÃO 3 — PROBLEMA
    ══════════════════════════════════ */
    #problema {
      background: var(--light);
      padding: 96px 24px;
    }
    .section-header {
      text-align: center;
      max-width: 680px;
      margin: 0 auto 56px;
    }
    .section-header h2 {
      font-size: clamp(26px, 3.5vw, 40px);
      font-weight: 800;
      color: var(--dark);
      line-height: 1.2;
      letter-spacing: -.02em;
      margin-bottom: 16px;
    }
    .section-header p {
      font-size: 17px;
      color: var(--gray);
      line-height: 1.65;
    }
    .cards-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      max-width: 1120px;
      margin: 0 auto;
    }
    .problem-card {
      background: #fff;
      border-radius: 16px;
      padding: 32px;
      border: 1.5px solid var(--border);
      transition: box-shadow .2s, transform .2s;
    }
    .problem-card:hover {
      box-shadow: 0 8px 32px rgba(0,0,0,.09);
      transform: translateY(-3px);
    }
    .problem-icon {
      width: 48px; height: 48px;
      border-radius: 12px;
      background: var(--orange-light);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      margin-bottom: 20px;
    }
    .problem-card h3 {
      font-size: 18px;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 12px;
      line-height: 1.3;
    }
    .problem-card p {
      font-size: 15px;
      color: var(--gray);
      line-height: 1.65;
    }
    .transition-banner {
      max-width: 720px;
      margin: 48px auto 0;
      text-align: center;
      padding: 28px 40px;
      background: linear-gradient(135deg, var(--orange) 0%, #FF6B35 100%);
      border-radius: 16px;
      color: #fff;
      font-size: 19px;
      font-weight: 600;
      line-height: 1.5;
    }

    /* ══════════════════════════════════
       SEÇÃO 4 — COMO FUNCIONA
    ══════════════════════════════════ */
    #como-funciona { padding: 96px 24px; background: #fff; }
    .steps-wrapper {
      max-width: 1120px;
      margin: 0 auto;
    }
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      position: relative;
      margin-bottom: 48px;
    }
    .steps-grid::before {
      content: '';
      position: absolute;
      top: 28px;
      left: calc(16.67% + 24px);
      right: calc(16.67% + 24px);
      height: 2px;
      background: linear-gradient(90deg, var(--orange) 0%, var(--orange) 100%);
      z-index: 0;
    }
    .step {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 32px;
      position: relative;
      z-index: 1;
    }
    .step-num {
      width: 56px; height: 56px;
      border-radius: 50%;
      background: var(--orange);
      color: #fff;
      font-size: 22px;
      font-weight: 800;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 24px;
      box-shadow: 0 0 0 6px var(--orange-light);
    }
    .step h3 {
      font-size: 19px;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 12px;
    }
    .step p { font-size: 15px; color: var(--gray); line-height: 1.65; }

    .step-cta-row {
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      gap: 10px;
    }
    .step-cta-micro { font-size: 13px; color: var(--gray); }

    /* ══════════════════════════════════
       SEÇÃO 5 — CATÁLOGO
    ══════════════════════════════════ */
    #catalogo {
      background: var(--orange);
      padding: 96px 24px;
      position: relative;
      overflow: hidden;
    }
    #catalogo::before {
      content: '';
      position: absolute;
      top: -80px; right: -80px;
      width: 400px; height: 400px;
      border-radius: 50%;
      background: rgba(255,255,255,.05);
    }
    .catalogo-inner {
      max-width: 1120px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
      position: relative;
    }
    .catalogo-left h2 {
      font-size: clamp(28px, 3.5vw, 42px);
      font-weight: 900;
      color: #fff;
      line-height: 1.15;
      letter-spacing: -.02em;
      margin-bottom: 16px;
    }
    .catalogo-left p {
      font-size: 17px;
      color: rgba(255,255,255,.82);
      line-height: 1.65;
      margin-bottom: 36px;
    }
    .catalogo-quote {
      background: rgba(255,255,255,.12);
      border-left: 3px solid rgba(255,255,255,.6);
      border-radius: 0 8px 8px 0;
      padding: 20px 24px;
      font-size: 15px;
      color: rgba(255,255,255,.88);
      line-height: 1.65;
      font-style: italic;
    }
    .categories-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .cat-chip {
      background: rgba(255,255,255,.13);
      border: 1.5px solid rgba(255,255,255,.25);
      border-radius: 12px;
      padding: 16px 18px;
      display: flex;
      align-items: center;
      gap: 12px;
      transition: background .18s;
    }
    .cat-chip:hover { background: rgba(255,255,255,.2); }
    .cat-chip .emoji { font-size: 22px; flex-shrink: 0; }
    .cat-chip .cat-info {}
    .cat-chip .cat-name { font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 2px; }
    .cat-chip .cat-desc { font-size: 12px; color: rgba(255,255,255,.65); }

    /* ══════════════════════════════════
       SEÇÃO 6 — PLATAFORMA RECONHEÇA
    ══════════════════════════════════ */
    #plataforma { background: var(--light); padding: 96px 24px; }
    .plataforma-inner {
      max-width: 1120px;
      margin: 0 auto;
    }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
    .feature-card {
      background: #fff;
      border-radius: 16px;
      padding: 36px;
      border: 1.5px solid var(--border);
      display: flex;
      gap: 20px;
      transition: box-shadow .2s;
    }
    .feature-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,.08); }
    .feature-icon {
      width: 52px; height: 52px;
      border-radius: 14px;
      background: var(--orange);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      flex-shrink: 0;
    }
    .feature-body h3 {
      font-size: 18px;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 10px;
    }
    .feature-body p { font-size: 15px; color: var(--gray); line-height: 1.65; }

    /* ══════════════════════════════════
       SEÇÃO 7 — PROVA SOCIAL
    ══════════════════════════════════ */
    #prova-social { background: #fff; padding: 96px 24px; }
    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
      max-width: 1120px;
      margin: 0 auto 56px;
    }
    .testimonial-card {
      background: var(--light);
      border-radius: 16px;
      padding: 36px;
      border: 1.5px solid var(--border);
      position: relative;
    }
    .quote-mark {
      font-size: 64px;
      font-weight: 900;
      color: var(--orange);
      line-height: 1;
      margin-bottom: 8px;
      font-family: Georgia, serif;
    }
    .testimonial-card blockquote {
      font-size: 16px;
      color: var(--dark);
      line-height: 1.7;
      margin-bottom: 24px;
      font-style: italic;
    }
    .testimonial-author {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .author-avatar {
      width: 44px; height: 44px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--orange) 0%, #FF6B35 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 16px;
      font-weight: 700;
      flex-shrink: 0;
    }
    .author-info .name { font-size: 15px; font-weight: 700; color: var(--dark); }
    .author-info .company { font-size: 13px; color: var(--gray); }

    .placeholder-card {
      background: #FFFBEB;
      border: 2px dashed #F59E0B;
      border-radius: 16px;
      padding: 36px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .placeholder-card .ph-icon { font-size: 28px; flex-shrink: 0; }
    .placeholder-card p { font-size: 14px; color: #92400E; line-height: 1.6; }

    /* logos reforço */
    .logos-reforco {
      max-width: 1120px;
      margin: 0 auto;
      text-align: center;
    }
    .logos-reforco p {
      font-size: 14px;
      color: var(--gray);
      margin-top: 24px;
    }

    /* ══════════════════════════════════
       SEÇÃO 8 — FORMULÁRIO
    ══════════════════════════════════ */
    #formulario {
      background: var(--light);
      padding: 96px 24px;
    }
    .form-wrapper {
      max-width: 1120px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 480px;
      gap: 80px;
      align-items: flex-start;
    }
    .form-left h2 {
      font-size: clamp(26px, 3vw, 38px);
      font-weight: 800;
      color: var(--dark);
      line-height: 1.2;
      letter-spacing: -.02em;
      margin-bottom: 16px;
    }
    .form-left p {
      font-size: 16px;
      color: var(--gray);
      line-height: 1.65;
      margin-bottom: 36px;
    }
    .trust-signals { display: flex; flex-direction: column; gap: 14px; }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 15px;
      color: var(--dark);
    }
    .trust-icon {
      width: 32px; height: 32px;
      border-radius: 8px;
      background: var(--orange-light);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }

    /* form card */
    .form-card {
      background: #fff;
      border-radius: 20px;
      padding: 40px;
      box-shadow: 0 16px 48px rgba(0,0,0,.1);
      border: 1px solid var(--border);
    }
    .form-card-header { margin-bottom: 28px; }
    .form-card-header h3 {
      font-size: 22px;
      font-weight: 800;
      color: var(--dark);
      margin-bottom: 6px;
    }
    .form-card-header p { font-size: 14px; color: var(--gray); }

    .form-group { margin-bottom: 20px; }
    .form-group label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: var(--dark);
      margin-bottom: 7px;
    }
    .form-group input,
    .form-group select {
      width: 100%;
      padding: 13px 16px;
      border: 1.5px solid var(--border);
      border-radius: 8px;
      font-size: 15px;
      font-family: inherit;
      color: var(--dark);
      background: #fff;
      transition: border-color .18s, box-shadow .18s;
      outline: none;
    }
    .form-group input:focus,
    .form-group select:focus {
      border-color: var(--orange);
      box-shadow: 0 0 0 3px rgba(232,68,10,.1);
    }
    .form-group input::placeholder { color: #9CA3AF; }

    .btn-submit {
      width: 100%;
      background: var(--green);
      color: #fff;
      font-size: 17px;
      font-weight: 700;
      padding: 17px 24px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: background .18s, transform .14s;
      margin-top: 8px;
      font-family: inherit;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .btn-submit:hover { background: var(--green-dark); transform: translateY(-1px); }

    .form-microcopy {
      text-align: center;
      font-size: 12px;
      color: #9CA3AF;
      margin-top: 14px;
      line-height: 1.5;
    }

    .form-trust-badge {
      margin-top: 20px;
      padding: 14px 16px;
      background: var(--orange-light);
      border-radius: 10px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: var(--orange-dark);
      font-weight: 600;
    }

    /* ══════════════════════════════════
       SEÇÃO 9 — FOOTER CTA
    ══════════════════════════════════ */
    #footer-cta {
      background: var(--dark);
      padding: 96px 24px;
    }
    .footer-cta-inner {
      max-width: 680px;
      margin: 0 auto;
      text-align: center;
    }
    .footer-cta-inner h2 {
      font-size: clamp(28px, 3.5vw, 44px);
      font-weight: 900;
      color: #fff;
      line-height: 1.15;
      letter-spacing: -.025em;
      margin-bottom: 20px;
    }
    .footer-cta-inner p {
      font-size: 17px;
      color: rgba(255,255,255,.65);
      line-height: 1.65;
      margin-bottom: 40px;
    }
    .footer-cta-inner .btn-primary {
      font-size: 18px;
      padding: 18px 40px;
    }
    .footer-target {
      margin-top: 16px;
      font-size: 13px;
      color: rgba(255,255,255,.4);
    }

    /* footer bar */
    footer {
      background: #0D1117;
      padding: 28px 24px;
      text-align: center;
      font-size: 13px;
      color: rgba(255,255,255,.3);
    }
    footer a { color: rgba(255,255,255,.4); text-decoration: none; }
